# ===== AutoStack Revenue Engine — Environment Variables =====
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# --- Google Gemini (Free AI Model) ---
# Get from: https://aistudio.google.com/app/apikey (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key

# --- Supabase ---
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# --- Gumroad ---
# Get from: Gumroad → Settings → Advanced
GUMROAD_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxx
GUMROAD_SELLER_ID=xxxxxxxxxxxxxxxxxxxxx
GUMROAD_USERNAME=nichereport

# --- Reddit API ---
# Get from: https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=xxxxxxxxxxxxx
REDDIT_SECRET=xxxxxxxxxxxxxxxxxxxxx
REDDIT_USER=your_reddit_username
REDDIT_PASS=your_reddit_password

# --- Mailchimp ---
# Get from: Mailchimp → Account → Extras → API Keys
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxx-usXX
MAILCHIMP_LIST_ID=xxxxxxxxxxxxx

# --- Amazon Associates ---
# Get from: https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG=yourtag-20

# --- App Config ---
# Secret for admin dashboard HTTP Basic Auth
ADMIN_PASSWORD=your_secure_admin_password

# Port for local development
PORT=3000

# Node environment
NODE_ENV=development
